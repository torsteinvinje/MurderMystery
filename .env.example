# Copy to .env and fill in the values from the Supabase dashboard
# (Project Settings -> API). Only these two PUBLIC values may ever appear
# in client code. The service-role key must NEVER go here or in the repo.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key
